{
  "name": "@safetnsr/shipart",
  "version": "2.0.0",
  "description": "generate README hero images for open source projects using AI — with dynamic theme generation",
  "type": "module",
  "bin": {
    "shipart": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "node --test tests/*.test.ts",
    "test:tsx": "npx tsx --test tests/*.test.ts"
  },
  "keywords": [
    "readme",
    "banner",
    "hero-image",
    "open-source",
    "cli",
    "ai",
    "gemini",
    "theme"
  ],
  "author": "safetnsr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/safetnsr/shipart.git"
  },
  "homepage": "https://github.com/safetnsr/shipart",
  "dependencies": {
    "@google/genai": "^1.0.0",
    "commander": "^12.0.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "optionalDependencies": {
    "playwright": "^1.40.0"
  },
  "engines": {
    "node": ">=20"
  }
}
